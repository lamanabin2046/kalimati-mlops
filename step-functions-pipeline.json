{
  "Comment": "Kalimati Tomato Price MLOps Pipeline with SNS Notifications",
  "StartAt": "Parallel Scraping",
  "States": {
    "Parallel Scraping": {
      "Type": "Parallel",
      "Next": "Notify Scraping Done",
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "Next": "Notify Pipeline Failed"
        }
      ],
      "Branches": [
        {
          "StartAt": "Weather Lambda",
          "States": {
            "Weather Lambda": {
              "Type": "Task",
              "Resource": "arn:aws:states:::lambda:invoke",
              "Parameters": {
                "FunctionName": "weather-ingestion",
                "Payload": {}
              },
              "Retry": [{"ErrorEquals": ["States.ALL"], "MaxAttempts": 2, "IntervalSeconds": 30}],
              "End": true
            }
          }
        },
        {
          "StartAt": "Diesel Lambda",
          "States": {
            "Diesel Lambda": {
              "Type": "Task",
              "Resource": "arn:aws:states:::lambda:invoke",
              "Parameters": {
                "FunctionName": "noc-diesel-scraper",
                "Payload": {}
              },
              "Retry": [{"ErrorEquals": ["States.ALL"], "MaxAttempts": 2, "IntervalSeconds": 30}],
              "End": true
            }
          }
        },
        {
          "StartAt": "News Lambda",
          "States": {
            "News Lambda": {
              "Type": "Task",
              "Resource": "arn:aws:states:::lambda:invoke",
              "Parameters": {
                "FunctionName": "news-event-ingestion",
                "Payload": {}
              },
              "Retry": [{"ErrorEquals": ["States.ALL"], "MaxAttempts": 2, "IntervalSeconds": 30}],
              "End": true
            }
          }
        },
        {
          "StartAt": "Kalimati Scraper",
          "States": {
            "Kalimati Scraper": {
              "Type": "Task",
              "Resource": "arn:aws:states:::ecs:runTask.sync",
              "Parameters": {
                "LaunchType": "FARGATE",
                "Cluster": "arn:aws:ecs:us-east-1:135723932609:cluster/kalimati-scrapers",
                "TaskDefinition": "kalimati-scraper-task",
                "NetworkConfiguration": {
                  "AwsvpcConfiguration": {
                    "Subnets": ["subnet-0129adadb19f31514"],
                    "SecurityGroups": ["sg-0685ac55b93979937"],
                    "AssignPublicIp": "ENABLED"
                  }
                },
                "Overrides": {
                  "ContainerOverrides": [
                    {
                      "Name": "kalimati-scraper",
                      "Environment": [{"Name": "SCRAPER_NAME", "Value": "kalimati_scraper"}]
                    }
                  ]
                }
              },
              "Retry": [{"ErrorEquals": ["States.ALL"], "MaxAttempts": 2, "IntervalSeconds": 60}],
              "End": true
            }
          }
        },
        {
          "StartAt": "Supply Scraper",
          "States": {
            "Supply Scraper": {
              "Type": "Task",
              "Resource": "arn:aws:states:::ecs:runTask.sync",
              "Parameters": {
                "LaunchType": "FARGATE",
                "Cluster": "arn:aws:ecs:us-east-1:135723932609:cluster/kalimati-scrapers",
                "TaskDefinition": "kalimati-scraper-task",
                "NetworkConfiguration": {
                  "AwsvpcConfiguration": {
                    "Subnets": ["subnet-0129adadb19f31514"],
                    "SecurityGroups": ["sg-0685ac55b93979937"],
                    "AssignPublicIp": "ENABLED"
                  }
                },
                "Overrides": {
                  "ContainerOverrides": [
                    {
                      "Name": "kalimati-scraper",
                      "Environment": [{"Name": "SCRAPER_NAME", "Value": "kalimati_supply_scraper"}]
                    }
                  ]
                }
              },
              "Retry": [{"ErrorEquals": ["States.ALL"], "MaxAttempts": 2, "IntervalSeconds": 60}],
              "End": true
            }
          }
        },
        {
          "StartAt": "NRB Exchange Scraper",
          "States": {
            "NRB Exchange Scraper": {
              "Type": "Task",
              "Resource": "arn:aws:states:::ecs:runTask.sync",
              "Parameters": {
                "LaunchType": "FARGATE",
                "Cluster": "arn:aws:ecs:us-east-1:135723932609:cluster/kalimati-scrapers",
                "TaskDefinition": "kalimati-scraper-task",
                "NetworkConfiguration": {
                  "AwsvpcConfiguration": {
                    "Subnets": ["subnet-0129adadb19f31514"],
                    "SecurityGroups": ["sg-0685ac55b93979937"],
                    "AssignPublicIp": "ENABLED"
                  }
                },
                "Overrides": {
                  "ContainerOverrides": [
                    {
                      "Name": "kalimati-scraper",
                      "Environment": [{"Name": "SCRAPER_NAME", "Value": "nrb_exchange_rate"}]
                    }
                  ]
                }
              },
              "Retry": [{"ErrorEquals": ["States.ALL"], "MaxAttempts": 2, "IntervalSeconds": 60}],
              "End": true
            }
          }
        },
        {
          "StartAt": "NRB Inflation Check",
          "States": {
            "NRB Inflation Check": {
              "Type": "Task",
              "Resource": "arn:aws:states:::lambda:invoke",
              "Parameters": {
                "FunctionName": "arn:aws:lambda:us-east-1:135723932609:function:nrb-inflation-check",
                "Payload": {}
              },
              "Retry": [
                {
                  "ErrorEquals": ["Lambda.ServiceException", "Lambda.AWSLambdaException", "Lambda.SdkClientException"],
                  "IntervalSeconds": 2,
                  "MaxAttempts": 3,
                  "BackoffRate": 2
                }
              ],
              "End": true
            }
          }
        }
      ]
    },
    "Notify Scraping Done": {
      "Type": "Task",
      "Resource": "arn:aws:states:::sns:publish",
      "Parameters": {
        "TopicArn": "arn:aws:sns:us-east-1:135723932609:kalimati-pipeline-alerts",
        "Subject": "\u2705 Kalimati Pipeline - Step 1 Complete",
        "Message": "All 7 scrapers completed successfully. Starting preprocessing..."
      },
      "Next": "Build Event Features",
      "Catch": [{"ErrorEquals": ["States.ALL"], "Next": "Build Event Features"}]
    },
    "Build Event Features": {
      "Type": "Task",
      "Resource": "arn:aws:states:::lambda:invoke",
      "Parameters": {
        "FunctionName": "build-event-features",
        "Payload": {}
      },
      "Retry": [{"ErrorEquals": ["States.ALL"], "MaxAttempts": 2, "IntervalSeconds": 30}],
      "Next": "Build Dataset",
      "Catch": [{"ErrorEquals": ["States.ALL"], "Next": "Notify Pipeline Failed"}]
    },
    "Build Dataset": {
      "Type": "Task",
      "Resource": "arn:aws:states:::lambda:invoke",
      "Parameters": {
        "FunctionName": "build-dataset",
        "Payload": {}
      },
      "Retry": [{"ErrorEquals": ["States.ALL"], "MaxAttempts": 2, "IntervalSeconds": 30}],
      "Next": "Notify Preprocessing Done",
      "Catch": [{"ErrorEquals": ["States.ALL"], "Next": "Notify Pipeline Failed"}]
    },
    "Notify Preprocessing Done": {
      "Type": "Task",
      "Resource": "arn:aws:states:::sns:publish",
      "Parameters": {
        "TopicArn": "arn:aws:sns:us-east-1:135723932609:kalimati-pipeline-alerts",
        "Subject": "\u2705 Kalimati Pipeline - Step 2 Complete",
        "Message": "Preprocessing completed. Feature dataset built successfully. Starting model training..."
      },
      "Next": "Train Model",
      "Catch": [{"ErrorEquals": ["States.ALL"], "Next": "Train Model"}]
    },
    "Train Model": {
      "Type": "Task",
      "Resource": "arn:aws:states:::lambda:invoke",
      "Parameters": {
        "FunctionName": "run-training",
        "Payload": {}
      },
      "Retry": [{"ErrorEquals": ["States.ALL"], "MaxAttempts": 1, "IntervalSeconds": 60}],
      "Next": "Drift Detector",
      "Catch": [{"ErrorEquals": ["States.ALL"], "Next": "Notify Pipeline Failed"}]
    },
    "Drift Detector": {
      "Type": "Task",
      "Resource": "arn:aws:states:::lambda:invoke",
      "Parameters": {
        "FunctionName": "drift-detection",
        "Payload": {}
      },
      "Retry": [{"ErrorEquals": ["States.ALL"], "MaxAttempts": 1, "IntervalSeconds": 30}],
      "Next": "Notify Training Done",
      "Catch": [{"ErrorEquals": ["States.ALL"], "Next": "Notify Training Done"}]
    },
    "Notify Training Done": {
      "Type": "Task",
      "Resource": "arn:aws:states:::sns:publish",
      "Parameters": {
        "TopicArn": "arn:aws:sns:us-east-1:135723932609:kalimati-pipeline-alerts",
        "Subject": "\u2705 Kalimati Pipeline - Model Trained",
        "Message": "XGBoost model training completed successfully! 7 models saved to S3. Reloading app..."
      },
      "Next": "Reload Model",
      "Catch": [{"ErrorEquals": ["States.ALL"], "Next": "Reload Model"}]
    },
    "Reload Model": {
      "Type": "Task",
      "Resource": "arn:aws:states:::lambda:invoke",
      "Parameters": {
        "FunctionName": "reload-model",
        "Payload": {}
      },
      "Retry": [{"ErrorEquals": ["States.ALL"], "MaxAttempts": 3, "IntervalSeconds": 30}],
      "Next": "Notify Pipeline Success",
      "Catch": [{"ErrorEquals": ["States.ALL"], "Next": "Notify Pipeline Failed"}]
    },
    "Notify Pipeline Success": {
      "Type": "Task",
      "Resource": "arn:aws:states:::sns:publish",
      "Parameters": {
        "TopicArn": "arn:aws:sns:us-east-1:135723932609:kalimati-pipeline-alerts",
        "Subject": "\ud83c\udf89 Kalimati Pipeline - All Done!",
        "Message": "Full pipeline completed! Scrapers \u2192 Preprocessing \u2192 Training \u2192 App updated. Tomato price predictions are fresh!"
      },
      "Next": "Pipeline Success",
      "Catch": [{"ErrorEquals": ["States.ALL"], "Next": "Pipeline Success"}]
    },
    "Pipeline Success": {
      "Type": "Succeed"
    },
    "Notify Pipeline Failed": {
      "Type": "Task",
      "Resource": "arn:aws:states:::sns:publish",
      "Parameters": {
        "TopicArn": "arn:aws:sns:us-east-1:135723932609:kalimati-pipeline-alerts",
        "Subject": "\u274c Kalimati Pipeline - FAILED",
        "Message": "Pipeline failed! Please check AWS Step Functions console for details."
      },
      "Next": "Pipeline Failed",
      "Catch": [{"ErrorEquals": ["States.ALL"], "Next": "Pipeline Failed"}]
    },
    "Pipeline Failed": {
      "Type": "Fail",
      "Error": "PipelineFailed",
      "Cause": "One or more pipeline steps failed"
    }
  }
}#␀ ␀u␀p␀d␀a␀t␀e␀␀
␀